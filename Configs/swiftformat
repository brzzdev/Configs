--swiftversion 6.3

# Exclude
--exclude Carthage,Pods,.build,.git,*.generated.swift

# Rules
--rules acronyms

--rules andOperator
--lintonly andOperator

--rules anyObjectProtocol

--rules applicationMain

--rules assertionFailures

--rules blankLineAfterImports

--rules blankLinesAroundMark

--rules blankLinesAtEndOfScope

--rules blankLinesAtStartOfScope

--rules blankLinesBetweenChainedFunctions

--rules blankLinesBetweenImports

--rules blankLinesBetweenScopes

--rules blockComments

--rules braces

--rules conditionalAssignment

--rules consecutiveBlankLines

--rules consecutiveSpaces

--rules consistentSwitchCaseSpacing

--rules duplicateImports

--rules elseOnSameLine

--rules emptyBraces

--rules emptyExtensions

--rules enumNamespaces

--rules extensionAccessControl
--extensionacl on-declarations

--rules fileHeader
--header strip

--rules genericExtensions

--rules hoistAwait

--rules hoistPatternLet

--rules hoistTry

--rules indent
--indent tab
--ifdef no-indent
--indentstrings true

--rules initCoderUnavailable

--rules leadingDelimiters

--rules linebreakAtEndOfFile

--rules linebreaks

--rules modifierOrder
--modifierorder nonisolated,override,private,fileprivate,internal,package,public,open,static,class,final,lazy,required,convenience,optional,dynamic,weak,unowned,mutating,nonmutating

--rules modifiersOnSameLine

--rules numberFormatting
--decimalgrouping 3, 4

--rules opaqueGenericParameters
--someAny disabled

--rules organizeDeclarations
--markcategories false
--organizationmode type
--organizetypes class,actor,struct,enum,extension

--rules preferCountWhere

--rules preferKeyPath

--rules privateStateVariables

--rules redundantAsync

--rules redundantBackticks

--rules redundantBreak

--rules redundantClosure

--rules redundantEquatable

--rules redundantExtensionACL

--rules redundantFileprivate

--rules redundantGet

--rules redundantInit

--rules redundantInternal

--rules redundantLet

--rules redundantLetError

--rules redundantMemberwiseInit

--rules redundantNilInit

--rules redundantObjc

--rules redundantOptionalBinding

--rules redundantParens

--rules redundantPattern

--rules redundantPublic

--rules redundantRawValues

--rules redundantReturn

--rules redundantSelf

--rules redundantSendable

--rules redundantStaticSelf

--rules redundantSwiftTestingSuite

--rules redundantThrows

--rules redundantType
--redundanttype inferred

--rules redundantTypedThrows

--rules redundantVariable

--rules redundantViewBuilder

--rules redundantVoidReturnType

--rules semicolons
--semicolons never

--rules simplifyGenericConstraints

--rules sortDeclarations

--rules sortImports

--rules sortSwitchCases

--rules sortTypealiases

--rules spaceAroundBraces

--rules spaceAroundBrackets

--rules spaceAroundComments

--rules spaceAroundGenerics

--rules spaceAroundOperators

--rules spaceAroundParens

--rules spaceInsideBraces

--rules spaceInsideBrackets

--rules spaceInsideComments

--rules spaceInsideGenerics

--rules spaceInsideParens

--rules strongifiedSelf

--rules todos

--rules trailingClosures

--rules trailingCommas

--rules trailingSpace

--rules typeSugar

--rules unusedArguments
--stripunusedargs closure-only

--rules void

--rules wrap
--maxwidth 100
--wrapternary before-operators

--rules wrapArguments
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--wrapconditions before-first
--wraptypealiases before-first

--rules wrapAttributes
--computedvarattrs prev-line
--funcattributes prev-line
--storedvarattrs same-line
--typeattributes prev-line

--rules wrapEnumCases

--rules wrapMultilineConditionalAssignment

--rules wrapMultilineFunctionChains

--rules wrapMultilineStatementBraces

--rules wrapSingleLineComments

--rules yodaConditions
